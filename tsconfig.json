{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@nakama/agent": ["packages/agent/src/index.ts"],
      "@nakama/client": ["packages/client/src/index.ts"],
      "@nakama/core": ["packages/core/src/index.ts"],
      "@nakama/core/*": ["packages/core/src/*"],
      "@nakama/db": ["packages/db/src/index.ts"]
    }
  }
}
